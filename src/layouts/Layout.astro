---
// 1. Style Sheets
import "../styles/global.css";
// 2. Components
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import PageHeading from "../components/PageHeading.astro";
// 3. Assets
import { Font } from "astro:assets";

interface Props {
    title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/levelsmith-website/favicon.svg" />
        <link rel="icon" href="/levelsmith-website/favicon.ico" />
        <Font cssVariable="--font-ibm-plex-mono" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body class="bg-medium text-primary">
        <!-- Navigation Bar -->
        <Navbar />
        <!-- Main Content -->
        <main>
            <!-- Heading -->
            <PageHeading title={title}/>
            <div class="w-fill h-fit px-[40px]">
                <!-- Body -->
                <slot />
            </div>
        </main>
        <!-- Footer -->
        <Footer />
    </body>
</html>
