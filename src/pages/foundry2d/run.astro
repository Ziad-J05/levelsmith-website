---
import "../../styles/global.css";
import { Font } from "astro:assets";
import SectionHeading from "../../components/SectionHeading.astro";
import ContactCardLarge from "../../components/ContactCardLarge.astro";
import Footer from "../../components/Footer.astro";
import LinkButton from "../../components/LinkButton.astro";
import Navbar from "../../components/Navbar.astro";
// images
import screencapF2dImage2 from "../../../src/assets/f2d-screencap-2.webp";
import screencapF2dImage3 from "../../../src/assets/f2d-screencap-3.webp";
import screencapF2dImage4 from "../../../src/assets/f2d-screencap-4.webp";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <link
            rel="icon"
            type="image/svg+xml"
            href="/levelsmith-website/favicon.svg"
        />
        <link rel="icon" href="/levelsmith-website/favicon.ico" />
        <Font cssVariable="--font-ibm-plex-mono" />
        <meta name="generator" content={Astro.generator} />
        <title>LevelSmith Labs</title>
    </head>
    <body class="bg-medium text-primary">
        <!-- Navigation Bar -->
        <Navbar />
        <!-- Main Content -->
        <main>
            <!-- Heading -->
            <div
                class="rounded-b-4xl flex flex-col gap-[8px] px-[20px] md:px-[40px] pt-[72px] pb-[16px] md:pb-[32px]
            bg-dark bg-[linear-gradient(to_right,#222222_2px,transparent_1px),linear-gradient(to_bottom,#222222_2px,transparent_1px)] bg-size-[64px_64px]"
            >
                <div class="hidden md:flex flex-row gap-[16px]">
                    <a
                        class="hover:underline text-primary"
                        href="/levelsmith-website/">Home</a
                    >
                    <p class="text-secondary">&gt;</p>
                    <a
                        class="hover:underline text-primary"
                        href="/levelsmith-website/foundry2d/"
                        >LevelSmith: Foundry 2D</a
                    >
                    <p class="text-secondary">&gt;</p>
                    <p class="text-secondary">Run in Browser</p>
                </div>

                <h1
                    class="text-3xl md:text-5xl font-bold uppercase text-center md:text-left tracking-wide"
                >
                    Run Foundry 2D
                </h1>
            </div>
            <div class="w-fill h-fit px-[40px]">
                <div class="mx-auto w-fit h-fit">
                    <!--<canvas id="canvas"></canvas> -->
                    <iframe
                        src="/levelsmith-website/Foundry 2D/Foundry 2D.html"
                        class=""
                        allow="autoplay; fullscreen; xr-spatial-tracking"
                        allowfullscreen></iframe>
                </div>

                <!-- Body -->
                <SectionHeading title="Credits" />
                <div
                    class="my-[48px] flex flex-col gap-[12px] mx-auto max-w-7xl"
                >
                    <p>
                        This project was developed by a team of twelve students
                        as an entrepreneurial co-op through Rochester Institute
                        of Technology.
                    </p>
                    <p><b>Producer:</b> Bee Morse</p>
                    <p><b>Tech Lead:</b> Theo Ruefli</p>
                    <p>
                        <b>Tech Team:</b> Andrew Hernandez, Ben Haines, Jack Xue,
                        Steven Poore, Theo Ruefli, Zay Arriaga
                    </p>
                    <p><b>Design Lead:</b> Chris Hamam</p>
                    <p>
                        <b>Design Team:</b> Chris Hamam, Deacon Mansfield, Evan Calkins,
                        Tyler Christ, Ziad Jaafar
                    </p>
                </div>
            </div>
        </main>

        <!-- Footer -->
        <Footer />
        <!--
        <script src="/levelsmith-website/Foundry 2D/Foundry 2D.js"></script>
        <script>
            var engine = new Engine({ executable: 'godot', unloadAfterInit: false });
            engine.startGame();
        </script>
         -->
    </body>
</html>
