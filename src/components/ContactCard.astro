---
interface Props {
	name: string;
	role: string;
	email?: string;
	phone?: string;
	website?: string;
}
const { name, role, email = null, phone = null, website = null } = Astro.props;
---

<div
	class="flex flex-col gap-[4px] border-1 border-primary rounded-lg px-[8px] pt-[8px] pb-[16px] w-xs h-fit"
>
	<p class="text-secondary">{role}</p>
	<h3 class="text-2xl font-medium">{name}</h3>
	<hr class="h-[1px] border-0 bg-secondary" />
	{
		email ? (
			<div class="flex flex-row gap-[8px]">
				<p>Email:</p>
				<a
					class="hover:text-primary active:text-accent text-accent-light"
					href={email}
				>
					{email}
				</a>
			</div>
		) : null
	}
	{
		phone ? (
			<div class="flex flex-row gap-[8px]">
				<p>Phone:</p>
				<a
					class="hover:text-primary active:text-accent text-accent-light"
					href={phone}
				>
					{phone}
				</a>
			</div>
		) : null
	}
	{
		website ? (
			<div class="flex flex-row gap-[8px]">
				<p>Website:</p>
				<a
					class="hover:text-primary active:text-accent text-accent-light"
					href={website}
				>
					{website}
				</a>
			</div>
		) : null
	}
</div>
